{
  "name": "osint-app",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "node scripts/dev.mjs",
    "dev:clean": "node scripts/dev.mjs --clean",
    "dev:fast": "node scripts/dev.mjs",
    "face": ".venv/bin/python python/face_server.py",
    "build": "next build",
    "postbuild": "node -e \"console.log('\\n[badgeros] After production build, use npm run dev (not dev:fast alone) if styles look unstyled.\\n')\"",
    "start": "next start",
    "lint": "next lint",
    "test": "node --import tsx --test src/lib/__tests__/**/*.test.ts"
  },
  "dependencies": {
    "better-sqlite3": "^12.10.0",
    "concurrently": "^10.0.3",
    "next": "^15.3.3",
    "react": "^19.1.0",
    "react-dom": "^19.1.0"
  },
  "devDependencies": {
    "@eslint/eslintrc": "^3.3.1",
    "@tailwindcss/postcss": "^4.1.8",
    "@types/better-sqlite3": "^7.6.13",
    "@types/node": "^22.15.21",
    "@types/react": "^19.1.6",
    "@types/react-dom": "^19.1.5",
    "eslint": "^9.27.0",
    "eslint-config-next": "^15.3.3",
    "tailwindcss": "^4.1.8",
    "tsx": "^4.22.4",
    "typescript": "^5.8.3"
  }
}

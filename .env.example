# BadgerOS — copy to .env.local

# No key needed (built-in)
# ip-api.com, ipwho.is, rdap.org, dns.google, crt.sh, internetdb.shodan.io
# archive.org, malwarebazaar, reddit public, hacker news, dev.to

# Free key (just register)
ABUSEIPDB_API_KEY=        # abuseipdb.com
VIRUSTOTAL_API_KEY=       # virustotal.com
ALIENVAULT_KEY=           # otx.alienvault.com
URLSCAN_KEY=              # urlscan.io
SECURITYTRAILS_KEY=       # securitytrails.com
PHISHTANK_KEY=            # phishtank.com
SHODAN_API_KEY=           # shodan.io
HIBP_API_KEY=             # haveibeenpwned.com (only paid one ~$3.50/mo — optional)
RAPIDAPI_KEY=             # rapidapi.com (for BreachDirectory)
EMAILREP_KEY=             # emailrep.io (optional, works without key too)
NUMVERIFY_KEY=            # apilayer.com — free
ABSTRACT_PHONE_KEY=       # abstractapi.com — free

# Plate / vehicle (free tiers)
PLATE_RECOGNIZER_KEY=     # platerecognizer.com — 2500 free/mo
DVLA_API_KEY=             # UK only — developer.gov.uk, free

# Face analysis (local Python server — npm run dev or npm run face)
# On Vercel: deploy python/face_server.py to Railway/Render/Fly and set this URL.
FACE_SERVER_URL=http://127.0.0.1:5001

# Reverse image search
SERPAPI_KEY=        # serpapi.com — 100 free searches/mo
BING_VISION_KEY=    # portal.azure.com — free tier (1000/mo)
TINEYE_KEY=         # tineye.com/api — free tier (150/mo)
IMGBB_KEY=          # imgbb.com — free image hosting for public URLs

NEXT_PUBLIC_BASE_URL=http://localhost:3000

# Optional: override SQLite path (Vercel uses /tmp automatically)
# RECON_DB_PATH=/tmp/recon.db
